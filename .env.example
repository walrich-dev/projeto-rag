# ── Provider do LLM ──────────────────────────────────────────────────────────
# Opções: ollama | gemini | openai
LLM_PROVIDER=ollama

# ── Nome do modelo ────────────────────────────────────────────────────────────
# Ollama:  phi3 | tinyllama | llama3.1 | mistral
# Gemini:  gemini-1.5-flash | gemini-1.5-pro
# OpenAI:  gpt-4o-mini | gpt-4o
MODEL_NAME=phi3

# ── API Keys ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...          # aistudio.google.com (GRATUITO)
OPENAI_API_KEY=sk-...
